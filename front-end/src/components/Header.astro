---
import profileImg from "../assets/profile.png"
---

<header class="flex gap-4 items-center mb-16">
	<img
		src={profileImg.src}
		alt="Profile image."
		fetchpriority="high"
		class="h-24 w-24 object-cover object-center rounded-full"
	/>
	<section>
		<h1 class="text-xl font-normal">Basty Winant</h1>
		<p class="mb-1 text-secondary">Full-Stack Developer</p>
		<span class="text-xs px-2.5 py-1 rounded-xl text-secondary bg-secondary/10">visit count: 28</span>
	</section>
</header>