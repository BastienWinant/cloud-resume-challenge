---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Container from "../components/Container.astro";
import Section from "../components/Section.astro";
import Project from '../components/Project.astro';
---

<Layout>
	<Container>
		<Header />
		<main class="flex flex-col gap-12">
			<Section title="about">
				<p class="text-secondary">
					I’m a passionate UX designer striving to create intuitive and engaging experiences.
					I’m a big believer that things can always be simpler than we think.
				</p>
			</Section>
			<Section title="projects">
				<div class="grid grid-cols-[repeat(auto-fit,minmax(200px,1fr))]">
					<Project
						demoLink="https://github.com/BastienWinant"
						description="This is the first project"
						githubLink="https://github.com/BastienWinant"
						imgUrl="https://images.unsplash.com/photo-1774677784803-fe0f6c9ce4ae"
						name="project 1"
					/>
				</div>
				<div class="grid grid-cols-[repeat(auto-fit,minmax(100px,1fr))]">
					<Project
						demoLink="https://github.com/BastienWinant"
						description="This is the second project"
						githubLink="https://github.com/BastienWinant"
						imgUrl="https://images.unsplash.com/photo-1774677784803-fe0f6c9ce4ae"
						name="project 2"
					/>
				</div>
			</Section>
			<Section title="certifications">
				<p>this is the certifications section</p>
			</Section>
			<Section title="contact">
				<p>this is the contact section</p>
			</Section>
		</main>
	</Container>
</Layout>
